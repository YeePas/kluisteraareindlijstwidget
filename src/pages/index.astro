---
const faviconHref = `${import.meta.env.BASE_URL.replace(/\/$/, '')}/favicon.svg`;
---

<html lang="nl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={faviconHref} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<title>Kluisteraar Eindlijst</title>
	</head>
	<body>
		<header>
			<p class="eyebrow">Luisterlijst</p>
			<h1>Kluisteraar Eindlijst</h1>
		</header>

		<section class="search">
			<form id="search-form">
				<input id="search-term" type="text" placeholder="Artiest of albumtitel..." autocomplete="off" required />
				<button type="submit">Zoeken</button>
			</form>
			<ul id="search-results" class="search-results" hidden></ul>
		</section>

		<main class="columns">
			<section class="panel" id="voorraad-panel" data-drop="voorraad">
				<h2>Voorraad</h2>
				<p class="hint">Albums die nog niet in de lijst staan. Sleep een kaart naar rechts om een positie te geven.</p>
				<div id="voorraad-grid" class="grid"></div>
			</section>

			<section class="panel">
				<h2>Eindlijst</h2>
				<p class="hint">Sleep kaarten om de volgorde te wijzigen. Sleep naar de lege plek onderaan om toe te voegen.</p>
				<ol id="leaderboard-list" class="leaderboard"></ol>
			</section>
		</main>

		<footer>
			<button id="export-csv-btn" class="primary" type="button">Exporteer CSV (Spotify / Apple Music)</button>
			<p class="hint" id="sync-status"></p>
		</footer>

		<script>
			import { doc, onSnapshot, setDoc } from 'firebase/firestore';
			import { db } from '../lib/firebase';

			const docRef = doc(db, 'eindlijst', 'main');

			/** @type {{leaderboard: any[], voorraad: any[]}} */
			let state = { leaderboard: [], voorraad: [] };

			const voorraadGrid = document.getElementById('voorraad-grid');
			const leaderboardList = document.getElementById('leaderboard-list');
			const voorraadPanel = document.getElementById('voorraad-panel');
			const searchForm = document.getElementById('search-form');
			const searchTermInput = document.getElementById('search-term');
			const searchResults = document.getElementById('search-results');
			const syncStatus = document.getElementById('sync-status');
			const exportCsvBtn = document.getElementById('export-csv-btn');

			function higherResArtwork(url) {
				return url.replace(/\d+x\d+bb\.jpg$/, '600x600bb.jpg');
			}

			function isKnown(id) {
				return (
					state.voorraad.some((a) => a.id === id) ||
					state.leaderboard.some((a) => a.id === id)
				);
			}

			function escapeHtml(value) {
				return String(value ?? '')
					.replaceAll('&', '&amp;')
					.replaceAll('<', '&lt;')
					.replaceAll('>', '&gt;')
					.replaceAll('"', '&quot;')
					.replaceAll("'", '&#39;');
			}

			function albumCardHtml(album) {
				return `
					<img src="${escapeHtml(album.artwork)}" alt="${escapeHtml(album.title)}" loading="lazy" />
					<div class="card-info">
						<strong>${escapeHtml(album.title)}</strong>
						<span>${escapeHtml(album.artist)}</span>
					</div>
				`;
			}

			function renderVoorraad() {
				voorraadGrid.innerHTML = '';
				for (const album of state.voorraad) {
					const card = document.createElement('div');
					card.className = 'card';
					card.draggable = true;
					card.dataset.source = 'voorraad';
					card.dataset.id = album.id;
					card.innerHTML =
						albumCardHtml(album) + `<button class="remove" data-remove-voorraad="${album.id}" title="Verwijderen">✕</button>`;
					voorraadGrid.appendChild(card);
				}
			}

			function renderLeaderboard() {
				leaderboardList.innerHTML = '';

				state.leaderboard.forEach((album, index) => {
					const li = document.createElement('li');
					li.className = 'slot filled';
					li.dataset.drop = 'leaderboard';
					li.dataset.index = String(index);

					const card = document.createElement('div');
					card.className = 'card';
					card.draggable = true;
					card.dataset.source = 'leaderboard';
					card.dataset.index = String(index);
					card.innerHTML =
						albumCardHtml(album) + `<button class="remove" data-return-index="${index}" title="Terug naar voorraad">↩</button>`;

					const position = document.createElement('span');
					position.className = 'position';
					position.textContent = String(index + 1);

					li.appendChild(position);
					li.appendChild(card);
					leaderboardList.appendChild(li);
				});

				const emptySlot = document.createElement('li');
				emptySlot.className = 'slot empty';
				emptySlot.dataset.drop = 'leaderboard';
				emptySlot.dataset.index = String(state.leaderboard.length);
				const position = document.createElement('span');
				position.className = 'position';
				position.textContent = String(state.leaderboard.length + 1);
				const emptyLabel = document.createElement('span');
				emptyLabel.textContent = 'Sleep hier een album naartoe';
				emptySlot.appendChild(position);
				emptySlot.appendChild(emptyLabel);
				leaderboardList.appendChild(emptySlot);
			}

			function renderAll() {
				renderVoorraad();
				renderLeaderboard();
			}

			function persist() {
				setDoc(docRef, { leaderboard: state.leaderboard, voorraad: state.voorraad })
					.then(() => {
						syncStatus.textContent = '';
					})
					.catch((err) => {
						console.error('Kon niet opslaan naar Firestore', err);
						syncStatus.textContent = 'Opslaan mislukt, controleer je verbinding.';
					});
			}

			function commit() {
				renderAll();
				persist();
			}

			onSnapshot(
				docRef,
				(snap) => {
					if (snap.exists()) {
						const data = snap.data();
						state = { leaderboard: data.leaderboard ?? [], voorraad: data.voorraad ?? [] };
					} else {
						state = { leaderboard: [], voorraad: [] };
						setDoc(docRef, state).catch((err) => console.error('Kon eindlijst niet aanmaken', err));
					}
					renderAll();
					syncStatus.textContent = '';
				},
				(err) => {
					console.error('Firestore sync error', err);
					syncStatus.textContent = 'Verbinden mislukt, controleer de Firebase-config.';
				},
			);

			// --- Search (JSONP, since the iTunes Search API has no CORS headers for fetch) ---
			let jsonpCounter = 0;
			function searchItunes(term) {
				return new Promise((resolve, reject) => {
					const callbackName = `itunesCb${jsonpCounter++}`;
					const script = document.createElement('script');
					window[callbackName] = (data) => {
						resolve(data.results ?? []);
						delete window[callbackName];
						script.remove();
					};
					script.onerror = () => {
						reject(new Error('Zoeken mislukt'));
						delete window[callbackName];
						script.remove();
					};
					script.src = `https://itunes.apple.com/search?entity=album&limit=10&term=${encodeURIComponent(term)}&callback=${callbackName}`;
					document.body.appendChild(script);
				});
			}

			// Sommige albums (bv. deluxe edities) komen niet in de album-zoekopdracht naar
			// boven, maar wel via de nummer-zoekopdracht. Dan leiden we de albums daaruit af.
			function searchItunesSongsAsAlbums(term) {
				return new Promise((resolve, reject) => {
					const callbackName = `itunesCb${jsonpCounter++}`;
					const script = document.createElement('script');
					window[callbackName] = (data) => {
						const seen = new Set();
						const albums = [];
						for (const r of data.results ?? []) {
							if (r.wrapperType !== 'track' || !r.collectionId) continue;
							if (seen.has(r.collectionId)) continue;
							seen.add(r.collectionId);
							albums.push({
								collectionId: r.collectionId,
								artistName: r.artistName,
								collectionName: r.collectionName,
								artworkUrl100: r.artworkUrl100,
							});
						}
						resolve(albums);
						delete window[callbackName];
						script.remove();
					};
					script.onerror = () => {
						reject(new Error('Zoeken mislukt'));
						delete window[callbackName];
						script.remove();
					};
					script.src = `https://itunes.apple.com/search?entity=song&limit=25&term=${encodeURIComponent(term)}&callback=${callbackName}`;
					document.body.appendChild(script);
				});
			}

			function lookupTracks(collectionId) {
				return new Promise((resolve, reject) => {
					const callbackName = `itunesCb${jsonpCounter++}`;
					const script = document.createElement('script');
					window[callbackName] = (data) => {
						const tracks = (data.results ?? []).filter((r) => r.wrapperType === 'track');
						resolve(tracks);
						delete window[callbackName];
						script.remove();
					};
					script.onerror = () => {
						reject(new Error('Tracklist ophalen mislukt'));
						delete window[callbackName];
						script.remove();
					};
					script.src = `https://itunes.apple.com/lookup?id=${encodeURIComponent(collectionId)}&entity=song&callback=${callbackName}`;
					document.body.appendChild(script);
				});
			}

			function csvEscape(value) {
				const str = String(value ?? '');
				return /[",\n]/.test(str) ? `"${str.replace(/"/g, '""')}"` : str;
			}

			exportCsvBtn.addEventListener('click', async () => {
				if (state.leaderboard.length === 0) {
					alert('De eindlijst is nog leeg.');
					return;
				}

				exportCsvBtn.disabled = true;
				const rows = [['Positie', 'Album', 'Artiest', 'Tracknummer', 'Nummer']];

				for (let i = 0; i < state.leaderboard.length; i++) {
					const album = state.leaderboard[i];
					exportCsvBtn.textContent = `Bezig... (${i + 1}/${state.leaderboard.length})`;
					try {
						const tracks = await lookupTracks(album.id);
						for (const track of tracks) {
							rows.push([i + 1, album.title, album.artist, track.trackNumber ?? '', track.trackName ?? '']);
						}
					} catch (err) {
						console.error(`Kon tracks voor "${album.title}" niet ophalen`, err);
						rows.push([i + 1, album.title, album.artist, '', '(tracklist niet gevonden)']);
					}
				}

				const csv = rows.map((row) => row.map(csvEscape).join(',')).join('\n');
				const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
				const url = URL.createObjectURL(blob);
				const a = document.createElement('a');
				a.href = url;
				a.download = 'eindlijst-tracklist.csv';
				a.click();
				URL.revokeObjectURL(url);

				exportCsvBtn.disabled = false;
				exportCsvBtn.textContent = 'Exporteer CSV (Spotify / Apple Music)';
			});

			searchForm.addEventListener('submit', async (e) => {
				e.preventDefault();
				const term = searchTermInput.value.trim();
				if (!term) return;

				searchResults.hidden = false;
				searchResults.innerHTML = '<li class="loading">Zoeken...</li>';

				let results;
				try {
					results = await searchItunes(term);
					if (results.length === 0) {
						results = await searchItunesSongsAsAlbums(term);
					}
				} catch {
					searchResults.innerHTML = '<li class="loading">Zoeken mislukt, probeer opnieuw.</li>';
					return;
				}

				if (results.length === 0) {
					searchResults.innerHTML = '<li class="loading">Niks gevonden.</li>';
					return;
				}

				searchResults.innerHTML = '';
				for (const result of results) {
					const id = String(result.collectionId);
					const album = {
						id,
						artist: result.artistName,
						title: result.collectionName,
						artwork: higherResArtwork(result.artworkUrl100),
					};

					const li = document.createElement('li');
					li.className = 'result';

					const img = document.createElement('img');
					img.src = album.artwork;
					img.alt = album.title;
					img.loading = 'lazy';

					const info = document.createElement('div');
					info.className = 'card-info';
					const title = document.createElement('strong');
					title.textContent = album.title;
					const artist = document.createElement('span');
					artist.textContent = album.artist;
					info.append(title, artist);

					const btn = document.createElement('button');
					const added = isKnown(id);
					btn.disabled = added;
					btn.textContent = added ? 'Toegevoegd' : '+ Toevoegen';
					btn._album = album;

					li.append(img, info, btn);
					searchResults.appendChild(li);
				}
			});

			document.addEventListener('click', (e) => {
				if (searchResults.hidden) return;
				if (e.target.closest('#search-form') || e.target.closest('#search-results')) return;
				searchResults.hidden = true;
			});

			searchResults.addEventListener('click', (e) => {
				const btn = e.target.closest('button');
				if (!btn) return;
				const album = btn._album;
				if (isKnown(album.id)) return;
				state.voorraad.push(album);
				btn.disabled = true;
				btn.textContent = 'Toegevoegd';
				commit();
			});

			// --- Remove / return buttons ---
			voorraadGrid.addEventListener('click', (e) => {
				const btn = e.target.closest('button[data-remove-voorraad]');
				if (!btn) return;
				const id = btn.dataset.removeVoorraad;
				state.voorraad = state.voorraad.filter((a) => a.id !== id);
				commit();
			});

			leaderboardList.addEventListener('click', (e) => {
				const btn = e.target.closest('button[data-return-index]');
				if (!btn) return;
				const index = Number(btn.dataset.returnIndex);
				const [album] = state.leaderboard.splice(index, 1);
				state.voorraad.push(album);
				commit();
			});

			// --- Drag and drop ---
			document.addEventListener('dragstart', (e) => {
				const card = e.target.closest('[draggable="true"]');
				if (!card) return;
				const payload =
					card.dataset.source === 'voorraad'
						? { source: 'voorraad', id: card.dataset.id }
						: { source: 'leaderboard', index: Number(card.dataset.index) };
				e.dataTransfer.setData('text/plain', JSON.stringify(payload));
				e.dataTransfer.effectAllowed = 'move';
			});

			function findDropTarget(e) {
				return e.target.closest('[data-drop]');
			}

			document.addEventListener('dragover', (e) => {
				const target = findDropTarget(e);
				if (!target) return;
				e.preventDefault();
				target.classList.add('dragover');
			});

			document.addEventListener('dragleave', (e) => {
				const target = findDropTarget(e);
				if (!target) return;
				target.classList.remove('dragover');
			});

			document.addEventListener('drop', (e) => {
				const target = findDropTarget(e);
				if (!target) return;
				e.preventDefault();
				target.classList.remove('dragover');

				const raw = e.dataTransfer.getData('text/plain');
				if (!raw) return;
				const payload = JSON.parse(raw);

				if (target.dataset.drop === 'voorraad') {
					if (payload.source !== 'leaderboard') return;
					const [album] = state.leaderboard.splice(payload.index, 1);
					state.voorraad.push(album);
					commit();
					return;
				}

				// dropping onto the leaderboard
				let targetIndex = Number(target.dataset.index);

				if (payload.source === 'voorraad') {
					const sourceIdx = state.voorraad.findIndex((a) => a.id === payload.id);
					if (sourceIdx === -1) return;
					const [album] = state.voorraad.splice(sourceIdx, 1);
					state.leaderboard.splice(targetIndex, 0, album);
				} else {
					const sourceIndex = payload.index;
					if (sourceIndex === targetIndex) return;
					const [album] = state.leaderboard.splice(sourceIndex, 1);
					if (sourceIndex < targetIndex) targetIndex -= 1;
					state.leaderboard.splice(targetIndex, 0, album);
				}

				commit();
			});
		</script>

		<style is:global>
			:root {
				color-scheme: light;
				--bg: #f3f3f0;
				--surface: #fbfbf9;
				--surface-alt: #f6f6f2;
				--border: #ddddda;
				--text: #171717;
				--muted: #6a6a6a;
				--accent: #171717;
				--red: #d23845;
				--red-hover: #ba2735;
				--radius: 2px;
				--font-serif: 'Iowan Old Style', 'Palatino Linotype', Palatino, 'Palatino LT STD',
					Georgia, serif;
				--font-sans: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue',
					Arial, sans-serif;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0 auto;
				max-width: 1100px;
				padding: 2.5rem 1.25rem 4rem;
				background: var(--bg);
				color: var(--text);
				font-family: var(--font-serif);
				font-size: 17px;
				line-height: 1.6;
				-webkit-font-smoothing: antialiased;
				-moz-osx-font-smoothing: grayscale;
			}

			.eyebrow {
				margin: 0 0 0.5rem;
				font-family: var(--font-sans);
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
				color: var(--muted);
			}

			header h1 {
				margin: 0 0 0.4rem;
				font-family: var(--font-sans);
				font-size: clamp(1.9rem, 1.4rem + 1.6vw, 2.6rem);
				font-weight: 800;
				line-height: 1.05;
				letter-spacing: -0.02em;
			}

			.subtitle,
			.hint {
				color: var(--muted);
				font-size: 0.95rem;
				margin: 0.25rem 0 1rem;
			}

			.search {
				margin: 2rem 0 2.5rem;
				position: relative;
			}

			#search-form {
				display: grid;
				grid-template-columns: minmax(0, 1fr) auto;
				gap: 0.5rem;
			}

			#search-term {
				min-width: 0;
				padding: 0.7rem 0.85rem;
				border-radius: var(--radius);
				border: 1px solid var(--border);
				background: var(--surface);
				color: var(--text);
				font-family: var(--font-sans);
				font-size: max(0.95rem, 16px);
			}

			#search-term::placeholder {
				color: var(--muted);
			}

			#search-term:focus {
				outline: none;
				border-color: var(--accent);
			}

			button {
				padding: 0.68rem 1rem;
				border-radius: var(--radius);
				border: 1px solid var(--border);
				background: transparent;
				color: var(--text);
				font-family: var(--font-sans);
				font-size: 0.85rem;
				font-weight: 700;
				cursor: pointer;
				transition: border-color 0.15s, color 0.15s, background 0.15s;
			}

			button:hover:not(:disabled),
			button:focus-visible:not(:disabled) {
				border-color: var(--accent);
				color: var(--accent);
			}

			button.primary {
				border-color: var(--red);
				background: var(--red);
				color: #fff;
			}

			button.primary:hover:not(:disabled),
			button.primary:focus-visible:not(:disabled) {
				border-color: var(--red-hover);
				background: var(--red-hover);
				color: #fff;
			}

			button:disabled {
				opacity: 0.5;
				cursor: default;
			}

			.search-results {
				list-style: none;
				margin: 0.4rem 0 0;
				padding: 0;
				position: absolute;
				z-index: 10;
				width: 100%;
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				max-height: 340px;
				overflow-y: auto;
				box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
			}

			.search-results li.result,
			.search-results li.loading {
				display: flex;
				align-items: center;
				gap: 0.8rem;
				padding: 0.6rem 0.8rem;
				border-bottom: 1px solid var(--border);
			}

			.search-results li:last-child {
				border-bottom: none;
			}

			.search-results li.loading {
				color: var(--muted);
				font-family: var(--font-sans);
				font-size: 0.78rem;
				letter-spacing: 0.06em;
				text-transform: uppercase;
			}

			.search-results img {
				width: 44px;
				height: 44px;
				border-radius: var(--radius);
				object-fit: cover;
			}

			.search-results .card-info {
				flex: 1;
				display: flex;
				flex-direction: column;
				gap: 0.1rem;
			}

			.search-results .card-info strong {
				font-style: italic;
				font-weight: 600;
				font-size: 0.98rem;
			}

			.search-results .card-info span {
				font-family: var(--font-sans);
				font-size: 0.68rem;
				font-weight: 600;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--muted);
			}

			.columns {
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 1.5rem;
			}

			.panel {
				background: var(--surface);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				padding: 1.4rem;
			}

			.panel h2 {
				margin: 0 0 0.25rem;
				font-family: var(--font-sans);
				font-size: 0.8rem;
				font-weight: 700;
				letter-spacing: 0.14em;
				text-transform: uppercase;
			}

			.grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
				gap: 0.85rem;
				min-height: 120px;
			}

			.card {
				position: relative;
				background: var(--surface-alt);
				border: 1px solid var(--border);
				border-radius: var(--radius);
				overflow: hidden;
				cursor: grab;
			}

			.card img {
				width: 100%;
				aspect-ratio: 1;
				object-fit: cover;
				display: block;
			}

			.card .card-info {
				padding: 0.55rem 0.6rem;
				display: flex;
				flex-direction: column;
				gap: 0.15rem;
			}

			.card .card-info strong {
				font-style: italic;
				font-weight: 600;
				font-size: 0.92rem;
				line-height: 1.25;
			}

			.card .card-info span {
				font-family: var(--font-sans);
				font-size: 0.64rem;
				font-weight: 600;
				letter-spacing: 0.07em;
				text-transform: uppercase;
				color: var(--muted);
			}

			.card .remove {
				position: absolute;
				top: 0.35rem;
				right: 0.35rem;
				padding: 0.05rem 0.4rem;
				min-height: 0;
				font-size: 0.8rem;
				line-height: 1.5;
				border-radius: var(--radius);
				background: rgba(255, 255, 255, 0.92);
				color: var(--text);
				border: 1px solid var(--border);
			}

			.leaderboard {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 0.55rem;
			}

			.slot {
				display: flex;
				align-items: center;
				gap: 0.85rem;
				border-radius: var(--radius);
				border: 1px solid transparent;
				padding: 0.45rem;
				min-height: 58px;
			}

			.slot.filled {
				border-color: var(--border);
				background: var(--surface-alt);
			}

			.slot.empty {
				color: var(--muted);
				border: 1px dashed var(--border);
				font-family: var(--font-sans);
				font-size: 0.78rem;
				letter-spacing: 0.04em;
			}

			.slot.dragover {
				border-color: var(--red);
				background: rgba(210, 56, 69, 0.06);
			}

			.position {
				font-family: var(--font-serif);
				font-weight: 700;
				font-size: 1.35rem;
				color: var(--text);
				width: 1.9rem;
				text-align: center;
				flex-shrink: 0;
			}

			.slot .card {
				flex: 1;
				display: flex;
				align-items: center;
				gap: 0.7rem;
				background: transparent;
				border: none;
				border-radius: 0;
				overflow: visible;
				cursor: grab;
			}

			.slot .card img {
				width: 48px;
				height: 48px;
				border-radius: var(--radius);
				flex-shrink: 0;
			}

			.slot .card .card-info {
				flex: 1;
				padding: 0;
			}

			footer {
				margin-top: 2.5rem;
				border-top: 1px solid var(--border);
				padding-top: 1.5rem;
			}

			#sync-status {
				font-family: var(--font-sans);
				font-size: 0.72rem;
				letter-spacing: 0.08em;
				text-transform: uppercase;
				color: var(--red);
			}

			#sync-status:empty {
				display: none;
			}

			#voorraad-panel.dragover {
				border-color: var(--red);
			}

			@media (max-width: 700px) {
				.columns {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</body>
</html>
